{
    "name": "jfsullivan/community-manager",
    "description": "A package to manage a community or organization",
    "keywords": [
        "jfsullivan",
        "laravel",
        "community-manager"
    ],
    "homepage": "https://github.com/jfsullivan/community-manager",
    "license": "MIT",
    "authors": [
        {
            "name": "Jack Sullivan",
            "email": "jfsullivan@foursullivans.com",
            "role": "Developer"
        }
    ],
    "repositories": {
        "flux-pro": {
            "type": "composer",
            "url": "https://composer.fluxui.dev"
        },
        "apex-ui": {
            "type": "vcs",
            "url": "https://github.com/jfsullivan/apex-ui"
        },
        "article-manager": {
            "type": "vcs",
            "url": "https://github.com/jfsullivan/article-manager"
        },
        "common-helpers": {
            "type": "vcs",
            "url": "https://github.com/jfsullivan/common-helpers"
        },
        "member-manager": {
            "type": "vcs",
            "url": "https://github.com/jfsullivan/member-manager"
        },
        "notifications": {
            "type": "vcs",
            "url": "https://github.com/jfsullivan/notifications"
        },
        "user-timezone": {
            "type": "vcs",
            "url": "https://github.com/jfsullivan/user-timezone"
        }
    },
    "require": {
        "php": "^8.2",
        "brick/money": "^0.8.1",
        "illuminate/contracts": "^11.0||^12.0",
        "jackiedo/timezonelist": "^5.1",
        "jfsullivan/article-manager": "^2.0",
        "jfsullivan/common-helpers": "^1.0",
        "jfsullivan/member-manager": "^0.9",
        "jfsullivan/notifications": "^1.0",
        "jfsullivan/user-timezone": "^1.0",
        "livewire/flux": "^2.0",
        "spatie/laravel-options": "^1.2",
        "spatie/laravel-package-tools": "^1.16.0",
        "spatie/laravel-sluggable": "^3.7"
    },
    "require-dev": {
        "laravel/pint": "^1.14",
        "livewire/flux-pro": "^2.0",
        "nunomaduro/collision": "^8.6",
        "larastan/larastan": "^3.0",
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-arch": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "spatie/laravel-ray": "^1.35"
    },
    "autoload": {
        "psr-4": {
            "jfsullivan\\CommunityManager\\": "src",
            "jfsullivan\\CommunityManager\\Database\\Factories\\": "database/factories"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "jfsullivan\\CommunityManager\\Tests\\": "tests"
        }
    },
    "scripts": {
        "post-autoload-dump": "@php ./vendor/bin/testbench package:discover --ansi",
        "analyse": "vendor/bin/phpstan analyse",
        "test": "@php vendor/pestphp/pest/bin/pest",
        "test-coverage": "@php vendor/pestphp/pest/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "jfsullivan\\CommunityManager\\CommunityManagerServiceProvider"
            ],
            "aliases": {
                "CommunityManager": "jfsullivan\\CommunityManager\\Facades\\CommunityManager"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
